<section class="sec reveal" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="wrap">
    <div class="sec-hd">
      <span class="tag">{{ section.settings.heading | default: 'Shop' }}</span>
      <h2 class="hdg">{{ section.settings.subheading | default: 'Cali K9<span class="reg">&reg;</span> <span class="b">Gear</span>' }}</h2>
      <div class="div div-c"></div>
      <p class="sub">{{ section.settings.subtext | default: 'Professional training equipment, apparel, and treats used by Jas and the Cali K9 team.' }}</p>
    </div>

    <div class="product-grid" style="margin-bottom:40px">
      {% assign block_products = false %}
      {% for block in section.blocks %}
        {% if block.type == 'product_feature' and block.settings.product != blank %}
          {% assign block_products = true %}
        {% endif %}
      {% endfor %}

      {% if block_products %}
        {% for block in section.blocks %}
          {% if block.type == 'product_feature' and block.settings.product != blank %}
            {% assign product = all_products[block.settings.product] %}
            <div class="prod-card" {{ block.shopify_attributes }}>
              <a href="{{ product.url }}" style="text-decoration:none;display:block">
                <div class="prod-img">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy">
                  {% endif %}
                </div>
                <div class="prod-info">
                  {% if block.settings.show_badge and block.settings.badge_text != blank %}
                    <div style="font-family:var(--font-cond);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:4px">{{ block.settings.badge_text }}</div>
                  {% endif %}
                  {% if block.settings.custom_label != blank %}
                    <div class="prod-name">{{ block.settings.custom_label }}</div>
                  {% else %}
                    <div class="prod-name">{{ product.title }}</div>
                  {% endif %}
                  <div class="prod-price">{{ product.price | money }}</div>
                </div>
              </a>
              <div style="padding:0 16px 16px">
                <button class="prod-btn" data-product-id="{{ product.variants.first.id }}" data-ajax-add>Add to Cart</button>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        {% assign featured_col = section.settings.collection | default: 'frontpage' %}
        {% assign featured = collections[featured_col].products | default: collections.all.products %}
        {% for product in featured limit: section.settings.limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% endif %}
    </div>

    <div style="text-align:center">
      <a href="/collections/all" class="btn btn-outline">View All Products</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tag / Eyebrow", "default": "Shop" },
    { "type": "text", "id": "subheading", "label": "Heading HTML", "default": "Cali K9<span class=\"reg\">&reg;</span> <span class=\"b\">Gear</span>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Professional training equipment, apparel, and treats used by Jas and the Cali K9 team." },
    { "type": "collection", "id": "collection", "label": "Fallback Collection" },
    { "type": "range", "id": "limit", "label": "Products to Show (fallback)", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "product_feature",
      "name": "Product Feature",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "custom_label", "label": "Custom Label (optional)", "default": "" },
        { "type": "checkbox", "id": "show_badge", "label": "Show Badge", "default": false },
        { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "Best Seller" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
