<div class="seen-on">
  <div class="wrap">
    <div class="so-inner">
      <span class="so-lbl">{{ section.settings.heading | default: 'As Seen On' }}</span>
      <div class="so-logos">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'logo' %}
              <span class="so-logo" {{ block.shopify_attributes }}>
                {% if block.settings.logo_image %}
                  <img src="{{ block.settings.logo_image | img_url: '160x60' }}" alt="{{ block.settings.name }}" style="max-height:40px;width:auto;object-fit:contain;opacity:.5;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.5">
                {% else %}
                  {{ block.settings.name }}
                {% endif %}
              </span>
            {% endif %}
          {% endfor %}
        {% else %}
          <span class="so-logo nfx">NETFLIX</span>
          <span class="so-logo">ESPN</span>
          <span class="so-logo">ABC7</span>
          <span class="so-logo">SF Chronicle</span>
          <span class="so-logo">Bay Area News</span>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Seen On",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As Seen On" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text", "id": "name", "label": "Name / Text", "default": "NETFLIX" },
        { "type": "image_picker", "id": "logo_image", "label": "Logo Image (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seen On",
      "blocks": [
        { "type": "logo", "settings": { "name": "NETFLIX" } },
        { "type": "logo", "settings": { "name": "ESPN" } },
        { "type": "logo", "settings": { "name": "ABC7" } },
        { "type": "logo", "settings": { "name": "SF Chronicle" } },
        { "type": "logo", "settings": { "name": "Bay Area News" } }
      ]
    }
  ]
}
{% endschema %}
