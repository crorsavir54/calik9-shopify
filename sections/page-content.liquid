<div class="page-content wrap" style="padding:80px 0 100px">
  {% if section.settings.show_title %}
    <h1 style="font-family:var(--font-display);font-size:clamp(40px,6vw,80px);color:var(--gi);margin-bottom:32px">
      {{ page.title }}
    </h1>
  {% endif %}
  <div class="rte" style="max-width:800px;margin:0 auto;font-size:17px;line-height:1.7;color:var(--text)">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Page Title",
      "default": true
    }
  ],
  "presets": [
    { "name": "Page Content" }
  ]
}
{% endschema %}
