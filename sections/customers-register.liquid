{%- liquid
  assign pt = section.settings.padding_top
  assign pb = section.settings.padding_bottom
  case section.settings.bg
    when 'white'
      assign bg_val = 'var(--w)'
    when 'dark'
      assign bg_val = 'var(--gi)'
    else
      assign bg_val = 'var(--off)'
  endcase
-%}

<section class="section reveal customer-auth-section" style="padding-top:{{ pt }}px;padding-bottom:{{ pb }}px;background:{{ bg_val }}">
  <div class="wrap">
    <div class="auth-card">
      <div class="auth-card__header">
        <h1 class="auth-card__title">{{ section.settings.heading }}</h1>
        <p class="auth-card__sub">{{ section.settings.subheading }}</p>
      </div>

      {% form 'create_customer' %}
        {{ form.errors | default_errors }}
        <div class="field-group-row">
          <div class="field-group">
            <label for="RegisterFirstName">First Name</label>
            <input type="text" name="customer[first_name]" id="RegisterFirstName" autocomplete="given-name">
          </div>
          <div class="field-group">
            <label for="RegisterLastName">Last Name</label>
            <input type="text" name="customer[last_name]" id="RegisterLastName" autocomplete="family-name">
          </div>
        </div>
        <div class="field-group">
          <label for="RegisterEmail">Email</label>
          <input type="email" name="customer[email]" id="RegisterEmail" autocomplete="email" required>
        </div>
        <div class="field-group">
          <label for="RegisterPassword">Password</label>
          <input type="password" name="customer[password]" id="RegisterPassword" autocomplete="new-password" required>
        </div>
        <button type="submit" class="btn btn-blue auth-submit-btn">Create Account</button>
        {% if section.settings.show_login_link %}
          <div class="auth-card__links" style="justify-content:center">
            <span>Already have an account? <a href="/account/login">Sign in</a></span>
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Register",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Create Account" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join the Cali K9 community" },
    { "type": "checkbox", "id": "show_login_link", "label": "Show login link", "default": true },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "off-white", "label": "Off White" },
        { "value": "white", "label": "White" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "off-white"
    },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 40, "max": 160, "step": 4, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 40, "max": 160, "step": 4, "default": 100, "unit": "px" }
  ],
  "presets": [{ "name": "Customer Register" }]
}
{% endschema %}
