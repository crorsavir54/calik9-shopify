{% assign vip_product = all_products[section.settings.vip_product] %}

<section class="hero-dark">
  <div class="hero-left">
    <div class="hero-eyebrow">
      <span class="tag" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:rgba(255,255,255,.7)">Premium &middot; Exclusive &middot; Results Guaranteed</span>
    </div>
    <h1 class="hdg-hero" style="font-size:clamp(42px,6vw,80px)">
      CALI K9<sup style="font-size:.4em;vertical-align:super">&reg;</sup><br>
      VIP DOG TRAINING<br>
      <em>PROGRAM</em>
    </h1>
    <p style="font-family:var(--font-cond);font-size:16px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:24px">
      5 Private Sessions &middot; Lifetime Access &middot; 1 Year Group Classes
    </p>
    <blockquote class="hero-quote">
      "When you commit to this program, I commit to you. We don't stop until your dog is everything you need them to be."
      <footer style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:10px;font-style:normal">&mdash; Jas Leverette</footer>
    </blockquote>

    {% if vip_product %}
      <form action="/cart/add" method="post" data-ajax-cart style="margin-bottom:24px">
        <input type="hidden" name="id" value="{{ vip_product.variants.first.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn btn-blue" style="font-size:16px;padding:18px 40px">
          Enroll Now &mdash; From $4,997
        </button>
      </form>
    {% else %}
      <a href="/pages/vip" class="btn btn-blue" style="font-size:16px;padding:18px 40px;margin-bottom:24px">
        Enroll Now &mdash; From $4,997
      </a>
    {% endif %}

    <div style="font-family:var(--font-cond);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.35)">
      &#128274; Secure &middot; Limited Enrollment &middot; Results Guaranteed
    </div>
  </div>

  <div class="hero-right" style="display:flex;align-items:center;justify-content:center;padding:40px">
    {% if section.settings.vip_image %}
      <img src="{{ section.settings.vip_image | img_url: '900x' }}" alt="VIP Dog Training Program" style="border-radius:var(--radius);max-height:560px;object-fit:cover;width:100%;position:relative;z-index:2">
    {% endif %}
    <div style="position:absolute;bottom:48px;right:48px;z-index:3;background:var(--blue);border-radius:var(--radius);padding:24px 32px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.3)">
      <div style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:4px">Starting From</div>
      <div style="font-family:var(--font-display);font-size:48px;color:#fff;line-height:1">$4,997</div>
      <div style="font-family:var(--font-cond);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:4px">5 Sessions</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VIP Hero",
  "settings": [
    { "type": "product", "id": "vip_product", "label": "VIP Product" },
    { "type": "image_picker", "id": "vip_image", "label": "VIP Image" }
  ],
  "presets": [{ "name": "VIP Hero" }]
}
{% endschema %}
