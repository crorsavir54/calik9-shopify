<section class="sec" style="background:var(--w);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="wrap">
    <div class="sec-hd reveal">
      <span class="tag">What You Get</span>
      <h2 class="hdg">{{ section.settings.heading | default: 'Everything Included in <span class="b">Your Evaluation</span>' }}</h2>
      <div class="div div-c"></div>
      <p class="sub">{{ section.settings.subtext | default: 'One powerful session designed to give you real answers and a clear path forward.' }}</p>
    </div>

    <div class="grid-2col reveal" style="gap:16px">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'item' %}
            <div class="inc-item" {{ block.shopify_attributes }}>
              <div class="inc-item-icon">{{ block.settings.icon_emoji }}</div>
              <div>
                <div class="inc-item-title">{{ block.settings.title }}</div>
                <div class="inc-item-desc">{{ block.settings.description }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="inc-item">
          <div class="inc-item-icon">&#128270;</div>
          <div>
            <div class="inc-item-title">Behavior Root Cause Analysis</div>
            <div class="inc-item-desc">Jas digs deep to find WHY your dog behaves the way it does &mdash; not just what it does.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#128203;</div>
          <div>
            <div class="inc-item-title">Custom Action Plan</div>
            <div class="inc-item-desc">You leave with a specific, written roadmap tailored to your dog's personality and your lifestyle.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#127775;</div>
          <div>
            <div class="inc-item-title">One-on-One with Jas</div>
            <div class="inc-item-desc">This is not an assistant or junior trainer. You get Jas Leverette directly.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#128218;</div>
          <div>
            <div class="inc-item-title">Handler Education</div>
            <div class="inc-item-desc">Learn the principles that make training stick &mdash; understanding that travels with you everywhere.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#127919;</div>
          <div>
            <div class="inc-item-title">Training Priority Roadmap</div>
            <div class="inc-item-desc">Know exactly what to work on first, second, and third for the fastest transformation.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#128241;</div>
          <div>
            <div class="inc-item-title">Program Recommendation</div>
            <div class="inc-item-desc">If your dog needs more work, Jas recommends the exact right next step &mdash; no upsell pressure.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#128276;</div>
          <div>
            <div class="inc-item-title">Real-World Context Assessment</div>
            <div class="inc-item-desc">We assess your dog in the environment where problems actually happen.</div>
          </div>
        </div>
        <div class="inc-item">
          <div class="inc-item-icon">&#9989;</div>
          <div>
            <div class="inc-item-title">Honest Answers</div>
            <div class="inc-item-desc">No fluff, no filler. Just straight talk about what your dog needs and how to get there.</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eval What's Included",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading HTML", "default": "Everything Included in <span class=\"b\">Your Evaluation</span>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "One powerful session designed to give you real answers and a clear path forward." },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Included Item",
      "settings": [
        { "type": "text", "id": "icon_emoji", "label": "Icon (emoji)", "default": "✅" },
        { "type": "text", "id": "title", "label": "Title", "default": "Behavior Root Cause Analysis" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Jas digs deep to find WHY your dog behaves the way it does." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Eval What's Included",
      "blocks": [
        { "type": "item", "settings": { "icon_emoji": "🔎", "title": "Behavior Root Cause Analysis", "description": "Jas digs deep to find WHY your dog behaves the way it does — not just what it does." } },
        { "type": "item", "settings": { "icon_emoji": "📋", "title": "Custom Action Plan", "description": "You leave with a specific, written roadmap tailored to your dog's personality and your lifestyle." } },
        { "type": "item", "settings": { "icon_emoji": "🌟", "title": "One-on-One with Jas", "description": "This is not an assistant or junior trainer. You get Jas Leverette directly." } },
        { "type": "item", "settings": { "icon_emoji": "📚", "title": "Handler Education", "description": "Learn the principles that make training stick — understanding that travels with you everywhere." } },
        { "type": "item", "settings": { "icon_emoji": "🎯", "title": "Training Priority Roadmap", "description": "Know exactly what to work on first, second, and third for the fastest transformation." } },
        { "type": "item", "settings": { "icon_emoji": "📱", "title": "Program Recommendation", "description": "If your dog needs more work, Jas recommends the exact right next step — no upsell pressure." } },
        { "type": "item", "settings": { "icon_emoji": "🔔", "title": "Real-World Context Assessment", "description": "We assess your dog in the environment where problems actually happen." } },
        { "type": "item", "settings": { "icon_emoji": "✅", "title": "Honest Answers", "description": "No fluff, no filler. Just straight talk about what your dog needs and how to get there." } }
      ]
    }
  ]
}
{% endschema %}
