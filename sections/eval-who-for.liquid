<section class="sec" style="background:var(--gi);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="wrap">
    <div class="grid-2col" style="align-items:start;gap:64px">
      <div class="reveal">
        <span class="tag" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:rgba(255,255,255,.6);margin-bottom:24px">Who This Is For</span>
        <h2 style="font-family:var(--font-display);font-size:clamp(36px,4vw,56px);color:#fff;line-height:1;margin-bottom:32px">
          {{ section.settings.heading | default: 'IS YOUR DOG <span style="color:rgba(255,255,255,.4)">STRUGGLING?</span>' }}
        </h2>
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'checklist_item' %}
              <div class="who-item" {{ block.shopify_attributes }}>
                <span class="who-check">&#10003;</span>
                <span class="who-text">{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">Your dog is reactive, aggressive, or unpredictable around people or other dogs</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">You've tried other trainers and nothing has worked long-term</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">Your dog pulls on leash, won't recall, or ignores basic commands</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">You're anxious or embarrassed by your dog's behavior in public</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">You've considered rehoming your dog but haven't given up yet</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">You just want real answers from the best in the business</span></div>
          <div class="who-item"><span class="who-check">&#10003;</span><span class="who-text">You have a new puppy and want to start with the right foundation</span></div>
        {% endif %}
      </div>

      <div class="reveal reveal-d2">
        <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--radius);padding:40px">
          <div style="text-align:center;margin-bottom:32px">
            <div style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:12px">Investment</div>
            <div style="font-family:var(--font-display);font-size:72px;color:#fff;line-height:1">{{ section.settings.price_display | default: '$27' }}</div>
            <div style="font-family:var(--font-cond);font-size:14px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5)">{{ section.settings.price_note | default: 'One Private Session' }}</div>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:24px">
            {% if section.blocks.size > 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'pricing_row' %}
                  <div class="pricing-row" {{ block.shopify_attributes }}>
                    <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">{{ block.settings.label }}</span>
                    <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">{{ block.settings.value }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            {% else %}
              <div class="pricing-row"><span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">One-on-One with Jas</span><span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span></div>
              <div class="pricing-row"><span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Custom Action Plan</span><span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span></div>
              <div class="pricing-row"><span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Behavior Analysis</span><span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span></div>
              <div class="pricing-row"><span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Training Roadmap</span><span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span></div>
            {% endif %}
          </div>
          <a href="/pages/eval" class="btn btn-blue" style="display:block;text-align:center;margin-top:32px;font-size:16px;padding:18px">
            Book Evaluation &mdash; {{ section.settings.price_display | default: '$27' }}
          </a>
          <p style="font-family:var(--font-cond);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:center;margin-top:12px">Limited spots available</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eval Who For",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading HTML", "default": "IS YOUR DOG <span style=\"color:rgba(255,255,255,.4)\">STRUGGLING?</span>" },
    { "type": "text", "id": "price_display", "label": "Price Display", "default": "$27" },
    { "type": "text", "id": "price_note", "label": "Price Note", "default": "One Private Session" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "checklist_item",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Your dog is reactive or unpredictable" }
      ]
    },
    {
      "type": "pricing_row",
      "name": "Pricing Row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "One-on-One with Jas" },
        { "type": "text", "id": "value", "label": "Value", "default": "✓ Included" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Eval Who For",
      "blocks": [
        { "type": "checklist_item", "settings": { "text": "Your dog is reactive, aggressive, or unpredictable around people or other dogs" } },
        { "type": "checklist_item", "settings": { "text": "You've tried other trainers and nothing has worked long-term" } },
        { "type": "checklist_item", "settings": { "text": "Your dog pulls on leash, won't recall, or ignores basic commands" } },
        { "type": "checklist_item", "settings": { "text": "You're anxious or embarrassed by your dog's behavior in public" } },
        { "type": "checklist_item", "settings": { "text": "You've considered rehoming your dog but haven't given up yet" } },
        { "type": "checklist_item", "settings": { "text": "You just want real answers from the best in the business" } },
        { "type": "checklist_item", "settings": { "text": "You have a new puppy and want to start with the right foundation" } },
        { "type": "pricing_row", "settings": { "label": "One-on-One with Jas", "value": "✓ Included" } },
        { "type": "pricing_row", "settings": { "label": "Custom Action Plan", "value": "✓ Included" } },
        { "type": "pricing_row", "settings": { "label": "Behavior Analysis", "value": "✓ Included" } },
        { "type": "pricing_row", "settings": { "label": "Training Roadmap", "value": "✓ Included" } }
      ]
    }
  ]
}
{% endschema %}
