{%- liquid
  assign pt = section.settings.padding_top
  assign pb = section.settings.padding_bottom
  case section.settings.bg
    when 'white'
      assign bg_val = 'var(--w)'
    when 'dark'
      assign bg_val = 'var(--gi)'
    else
      assign bg_val = 'var(--off)'
  endcase
-%}

<section class="section reveal customer-auth-section" style="padding-top:{{ pt }}px;padding-bottom:{{ pb }}px;background:{{ bg_val }}">
  <div class="wrap">
    <div class="auth-card">
      <div class="auth-card__header">
        <h1 class="auth-card__title">{{ section.settings.heading }}</h1>
        <p class="auth-card__sub">{{ section.settings.subheading }}</p>
      </div>

      {% form 'activate_customer_password' %}
        {{ form.errors | default_errors }}
        <div class="field-group">
          <label for="ActivatePassword">Password</label>
          <input type="password" name="customer[password]" id="ActivatePassword" autocomplete="new-password" required>
        </div>
        <div class="field-group">
          <label for="ActivatePasswordConfirm">Confirm Password</label>
          <input type="password" name="customer[password_confirmation]" id="ActivatePasswordConfirm" autocomplete="new-password" required>
        </div>
        <button type="submit" class="btn btn-blue auth-submit-btn">Activate Account</button>
        <div class="auth-card__links" style="justify-content:center">
          <a href="/account/login">Already have an account? Sign in</a>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Activate Account",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Activate Your Account" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Create a password to complete your account setup." },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "off-white", "label": "Off White" },
        { "value": "white", "label": "White" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "off-white"
    },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 40, "max": 160, "step": 4, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 40, "max": 160, "step": 4, "default": 100, "unit": "px" }
  ],
  "presets": [{ "name": "Customer Activate Account" }]
}
{% endschema %}
