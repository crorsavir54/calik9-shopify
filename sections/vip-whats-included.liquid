<section class="sec" style="background:var(--w);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="wrap">
    <div class="sec-hd reveal">
      <span class="tag">What You Get</span>
      <h2 class="hdg">{{ section.settings.heading | default: 'Everything Included in <span class="b">VIP Training</span>' }}</h2>
      <div class="div div-c"></div>
      <p class="sub">{{ section.settings.subtext | default: "The most comprehensive dog training experience available. Jas's personal commitment to your dog's transformation." }}</p>
    </div>

    <div class="grid-2col reveal" style="gap:16px">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'item' %}
            <div class="inc-item" {{ block.shopify_attributes }}>
              <div class="inc-item-icon">{{ block.settings.icon_emoji }}</div>
              <div>
                <div class="inc-item-title">{{ block.settings.title }}</div>
                <div class="inc-item-desc">{{ block.settings.description }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="inc-item"><div class="inc-item-icon">&#9889;</div><div><div class="inc-item-title">5 Private 2-Hour Sessions</div><div class="inc-item-desc">Five intensive one-on-one sessions with Jas Leverette personally &mdash; 10 total hours of elite training.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#127891;</div><div><div class="inc-item-title">Lifetime Online Course Access</div><div class="inc-item-desc">Full access to Cali K9&reg;'s complete online training library. Watch, rewatch, and reinforce forever.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#128101;</div><div><div class="inc-item-title">1 Year of Group Classes</div><div class="inc-item-desc">Weekly group sessions to reinforce skills in real-world environments alongside other trained dogs.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#127968;</div><div><div class="inc-item-title">Board &amp; Train Option</div><div class="inc-item-desc">Optional residential training where your dog lives and trains with Jas for accelerated results.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#128203;</div><div><div class="inc-item-title">Custom Training Plan</div><div class="inc-item-desc">A personalized blueprint built specifically for your dog's breed, age, temperament, and your goals.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#127758;</div><div><div class="inc-item-title">Real-World Environments</div><div class="inc-item-desc">Training happens where life happens &mdash; parks, streets, stores, and busy public environments.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#128218;</div><div><div class="inc-item-title">Handler Education</div><div class="inc-item-desc">You become a trained handler too. The knowledge transfers to every dog you'll ever own.</div></div></div>
        <div class="inc-item"><div class="inc-item-icon">&#128200;</div><div><div class="inc-item-title">Progress Tracking</div><div class="inc-item-desc">Detailed notes and video review after each session so you can see exactly how far your dog has come.</div></div></div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VIP What's Included",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading HTML", "default": "Everything Included in <span class=\"b\">VIP Training</span>" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "The most comprehensive dog training experience available. Jas's personal commitment to your dog's transformation." },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Included Item",
      "settings": [
        { "type": "text", "id": "icon_emoji", "label": "Icon (emoji)", "default": "⚡" },
        { "type": "text", "id": "title", "label": "Title", "default": "5 Private 2-Hour Sessions" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Five intensive one-on-one sessions with Jas Leverette personally." }
      ]
    }
  ],
  "presets": [
    {
      "name": "VIP What's Included",
      "blocks": [
        { "type": "item", "settings": { "icon_emoji": "⚡", "title": "5 Private 2-Hour Sessions", "description": "Five intensive one-on-one sessions with Jas Leverette personally — 10 total hours of elite training." } },
        { "type": "item", "settings": { "icon_emoji": "🎓", "title": "Lifetime Online Course Access", "description": "Full access to Cali K9®'s complete online training library. Watch, rewatch, and reinforce forever." } },
        { "type": "item", "settings": { "icon_emoji": "👥", "title": "1 Year of Group Classes", "description": "Weekly group sessions to reinforce skills in real-world environments alongside other trained dogs." } },
        { "type": "item", "settings": { "icon_emoji": "🏠", "title": "Board & Train Option", "description": "Optional residential training where your dog lives and trains with Jas for accelerated results." } },
        { "type": "item", "settings": { "icon_emoji": "📋", "title": "Custom Training Plan", "description": "A personalized blueprint built specifically for your dog's breed, age, temperament, and your goals." } },
        { "type": "item", "settings": { "icon_emoji": "🌍", "title": "Real-World Environments", "description": "Training happens where life happens — parks, streets, stores, and busy public environments." } },
        { "type": "item", "settings": { "icon_emoji": "📚", "title": "Handler Education", "description": "You become a trained handler too. The knowledge transfers to every dog you'll ever own." } },
        { "type": "item", "settings": { "icon_emoji": "📈", "title": "Progress Tracking", "description": "Detailed notes and video review after each session so you can see exactly how far your dog has come." } }
      ]
    }
  ]
}
{% endschema %}
