<section style="background:linear-gradient(135deg,var(--blue) 0%,var(--gi) 100%);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;text-align:center">
  <div class="wrap-sm">
    <div class="reveal">
      <span class="tag" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.8);margin-bottom:32px">Elite Training</span>
      <h2 style="font-family:var(--font-display);font-size:clamp(48px,7vw,88px);color:#fff;line-height:.95;margin-bottom:16px">
        {{ section.settings.heading | default: 'YOUR DOG.<br><span style="color:rgba(255,255,255,.45)">TRANSFORMED.</span>' }}
      </h2>
      <p style="font-family:var(--font-body);font-size:18px;color:rgba(255,255,255,.75);margin-bottom:12px;line-height:1.7">
        {{ section.settings.body | default: "The Cali K9® VIP program is the most comprehensive dog training experience available. Jas's personal commitment. Real results." }}
      </p>
      <div style="font-family:var(--font-cond);font-size:16px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:8px">Starting From</div>
      <div style="font-family:var(--font-display);font-size:72px;color:#fff;margin:0 0 32px">{{ section.settings.price_display | default: '$4,997' }}</div>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px">
        <a href="{{ section.settings.cta_url | default: '/pages/vip' }}" class="btn btn-white" style="font-size:17px;padding:20px 40px">
          {{ section.settings.cta_text | default: 'Start with an Evaluation — $27' }}
        </a>
        {% if section.settings.secondary_cta_text != blank %}
          <a href="{{ section.settings.secondary_cta_url | default: '/pages/vip' }}" class="btn btn-outline-white" style="font-size:17px;padding:20px 40px">
            {{ section.settings.secondary_cta_text }}
          </a>
        {% endif %}
      </div>
      <p style="font-family:var(--font-cond);font-size:12px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35)">
        {{ section.settings.fine_print | default: '🔒 Secure · Limited Enrollment · Results Guaranteed' }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VIP Final CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading HTML", "default": "YOUR DOG.<br><span style=\"color:rgba(255,255,255,.45)\">TRANSFORMED.</span>" },
    { "type": "textarea", "id": "body", "label": "Body Text", "default": "The Cali K9® VIP program is the most comprehensive dog training experience available. Jas's personal commitment. Real results." },
    { "type": "text", "id": "price_display", "label": "Price Display", "default": "$4,997" },
    { "type": "text", "id": "cta_text", "label": "Primary CTA Text", "default": "Start with an Evaluation — $27" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL", "default": "/pages/vip" },
    { "type": "text", "id": "secondary_cta_text", "label": "Secondary CTA Text (leave blank to hide)", "default": "Learn More" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL", "default": "/pages/vip" },
    { "type": "text", "id": "fine_print", "label": "Fine Print", "default": "🔒 Secure · Limited Enrollment · Results Guaranteed" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "VIP Final CTA" }]
}
{% endschema %}
