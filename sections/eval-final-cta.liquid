<section style="background:linear-gradient(135deg,var(--blue) 0%,var(--gi) 100%);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;text-align:center">
  <div class="wrap-sm">
    <div class="reveal">
      <span class="tag" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.8);margin-bottom:32px">Last Chance</span>
      <h2 style="font-family:var(--font-display);font-size:clamp(48px,7vw,88px);color:#fff;line-height:.95;margin-bottom:16px">
        {{ section.settings.heading | default: 'STOP GUESSING.<br><span style="color:rgba(255,255,255,.45)">GET ANSWERS.</span>' }}
      </h2>
      <p style="font-family:var(--font-body);font-size:18px;color:rgba(255,255,255,.75);margin-bottom:12px;line-height:1.7">
        {{ section.settings.body | default: 'For just $27, you get one private session with Jas Leverette — the trainer trusted by Netflix, NBA champions, and Grammy winners.' }}
      </p>
      <div style="font-family:var(--font-display);font-size:72px;color:#fff;margin:24px 0">{{ section.settings.price_display | default: '$27' }}</div>
      <a href="{{ section.settings.cta_url | default: '/pages/eval' }}" class="btn btn-white" style="font-size:17px;padding:20px 48px;margin-bottom:24px">
        {{ section.settings.cta_text | default: 'Book My Evaluation Now' }}
      </a>
      <p style="font-family:var(--font-cond);font-size:12px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35)">
        {{ section.settings.fine_print | default: '🔒 Secure · Instant Confirmation · Limited Spots Daily' }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eval Final CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading HTML", "default": "STOP GUESSING.<br><span style=\"color:rgba(255,255,255,.45)\">GET ANSWERS.</span>" },
    { "type": "textarea", "id": "body", "label": "Body Text", "default": "For just $27, you get one private session with Jas Leverette — the trainer trusted by Netflix, NBA champions, and Grammy winners." },
    { "type": "text", "id": "price_display", "label": "Price Display", "default": "$27" },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Book My Evaluation Now" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "text", "id": "fine_print", "label": "Fine Print", "default": "🔒 Secure · Instant Confirmation · Limited Spots Daily" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "Eval Final CTA" }]
}
{% endschema %}
