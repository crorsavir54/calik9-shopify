<section style="background:linear-gradient(135deg,var(--blue) 0%,var(--gi) 100%);padding:100px 0;text-align:center">
  <div class="wrap-sm">
    <div class="reveal">
      <span class="tag" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.8);margin-bottom:32px">Last Chance</span>
      <h2 style="font-family:var(--font-display);font-size:clamp(48px,7vw,88px);color:#fff;line-height:.95;margin-bottom:16px">
        STOP GUESSING.<br>
        <span style="color:rgba(255,255,255,.45)">GET ANSWERS.</span>
      </h2>
      <p style="font-family:var(--font-body);font-size:18px;color:rgba(255,255,255,.75);margin-bottom:12px;line-height:1.7">
        For just $27, you get one private session with Jas Leverette &mdash; the trainer trusted by Netflix, NBA champions, and Grammy winners.
      </p>
      <div style="font-family:var(--font-display);font-size:72px;color:#fff;margin:24px 0">$27</div>
      <a href="#eval-booking" class="btn btn-white" style="font-size:17px;padding:20px 48px;margin-bottom:24px">
        Book My Evaluation Now
      </a>
      <p style="font-family:var(--font-cond);font-size:12px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35)">
        &#128274; Secure &middot; Instant Confirmation &middot; Limited Spots Daily
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eval Final CTA",
  "presets": [{ "name": "Eval Final CTA" }]
}
{% endschema %}
