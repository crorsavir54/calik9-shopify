<div class="product-page">
  <div class="wrap">
    <div class="grid-2col" style="align-items:start">

      <!-- Gallery -->
      <div class="product-gallery">
        <div class="product-gallery-main" id="gallery-main">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" id="main-img">
          {% else %}
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--off);color:var(--gm)">No Image</div>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-thumbs">
            {% for image in product.images limit: 6 %}
              <div class="product-thumb {% if forloop.first %}active{% endif %}" onclick="document.getElementById('main-img').src='{{ image | img_url: '800x' }}';document.querySelectorAll('.product-thumb').forEach(t=>t.classList.remove('active'));this.classList.add('active')">
                <img src="{{ image | img_url: '150x' }}" alt="{{ product.title }} image {{ forloop.index }}">
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Info -->
      <div class="product-info">
        <div style="margin-bottom:12px">
          {% if product.collections.first %}
            <a href="{{ product.collections.first.url }}" style="font-family:var(--font-cond);font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue);text-decoration:none">
              {{ product.collections.first.title }}
            </a>
          {% endif %}
        </div>
        <h1>{{ product.title }}</h1>
        <div class="product-price">{{ product.price | money }}</div>

        {% if product.description != blank %}
          <div class="product-desc">{{ product.description }}</div>
        {% endif %}

        <form action="/cart/add" method="post" data-ajax-cart>
          {% if product.variants.size > 1 %}
            <div style="margin-bottom:20px">
              <label style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--gi);display:block;margin-bottom:8px">Options</label>
              <select name="id" style="width:100%;padding:12px 16px;border:1px solid var(--bo);border-radius:var(--radius-sm);font-family:var(--font-cond);font-size:15px;font-weight:600;color:var(--gi);background:#fff;cursor:pointer">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} &mdash; {{ variant.price | money }}{% unless variant.available %} (Sold Out){% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          {% endif %}

          <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
            <label style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--gi)">Qty</label>
            <input type="number" name="quantity" value="1" min="1" style="width:72px;padding:10px 12px;border:1px solid var(--bo);border-radius:var(--radius-sm);font-family:var(--font-cond);font-size:15px;font-weight:700;color:var(--gi);text-align:center">
          </div>

          {% if product.available %}
            <button type="submit" class="btn btn-blue" style="width:100%;justify-content:center;font-size:16px;padding:18px">
              Add to Cart &mdash; {{ product.price | money }}
            </button>
          {% else %}
            <button type="button" class="btn" style="width:100%;justify-content:center;font-size:16px;padding:18px;background:var(--gm);color:#fff;cursor:not-allowed" disabled>
              Sold Out
            </button>
          {% endif %}
        </form>

        <div class="trust-badges" style="margin-top:24px;padding-top:24px;border-top:1px solid var(--bo)">
          <div class="trust-badge">&#128274; Secure Checkout</div>
          <div class="trust-badge">&#128666; Free Shipping Over $75</div>
          <div class="trust-badge">&#8635; Easy Returns</div>
          <div class="trust-badge">&#128717; Jas-Approved Gear</div>
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main Product",
  "presets": [{ "name": "Main Product" }]
}
{% endschema %}
