<section class="sec" style="background:var(--gi)">
  <div class="wrap">
    <div class="grid-2col" style="align-items:start;gap:64px">
      <div class="reveal">
        <span class="tag" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:rgba(255,255,255,.6);margin-bottom:24px">Who This Is For</span>
        <h2 style="font-family:var(--font-display);font-size:clamp(36px,4vw,56px);color:#fff;line-height:1;margin-bottom:32px">
          READY FOR <span style="color:rgba(255,255,255,.4)">ELITE RESULTS?</span>
        </h2>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">You want the absolute best training available &mdash; no compromises</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">Your dog has serious behavior issues that require expert-level intervention</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">You value your time and want the fastest, most effective transformation possible</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">You want one-on-one access to Jas Leverette himself, not an assistant</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">You want to become a skilled handler, not just have a temporarily trained dog</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">Your dog is a working dog, sport dog, or high-drive breed needing elite guidance</span>
        </div>
        <div class="who-item">
          <span class="who-check">&#10003;</span>
          <span class="who-text">You want lifetime access to training resources and ongoing community support</span>
        </div>
      </div>

      <div class="reveal reveal-d2">
        <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--radius);padding:40px">
          <div style="text-align:center;margin-bottom:32px">
            <div style="font-family:var(--font-cond);font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:12px">Investment</div>
            <div style="font-family:var(--font-cond);font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:4px">Starting From</div>
            <div style="font-family:var(--font-display);font-size:64px;color:#fff;line-height:1">$4,997</div>
            <div style="font-family:var(--font-cond);font-size:14px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5)">5 Private Sessions</div>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:24px">
            <div class="pricing-row">
              <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">5 Private 2-Hour Sessions</span>
              <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span>
            </div>
            <div class="pricing-row">
              <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Lifetime Online Course</span>
              <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span>
            </div>
            <div class="pricing-row">
              <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">1 Year Group Classes</span>
              <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span>
            </div>
            <div class="pricing-row">
              <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Custom Training Plan</span>
              <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Included</span>
            </div>
            <div class="pricing-row" style="border:none;padding-bottom:0">
              <span style="font-family:var(--font-cond);font-size:15px;color:rgba(255,255,255,.7)">Board &amp; Train Option</span>
              <span style="color:#4ade80;font-family:var(--font-cond);font-weight:700">&#10003; Available</span>
            </div>
          </div>
          <a href="/pages/eval" class="btn btn-blue" style="display:block;text-align:center;margin-top:32px;font-size:16px;padding:18px">
            Start with an Evaluation &mdash; $27
          </a>
          <p style="font-family:var(--font-cond);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:center;margin-top:12px">Book an eval first to see if VIP is right for you</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VIP Who For",
  "presets": [{ "name": "VIP Who For" }]
}
{% endschema %}
