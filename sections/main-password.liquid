<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --blue: #1A3FAB;
      --gi: #0a1a5c;
      --off: #f5f2eb;
      --w: #ffffff;
      --bo: #e0ddd6;
      --font-display: 'Bebas Neue', sans-serif;
      --font-cond: 'Barlow Condensed', sans-serif;
      --font-body: 'Barlow', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); background: var(--gi); color: var(--w); min-height: 100vh; display: flex; flex-direction: column; }
    .pw-wrap { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 24px; }
    .pw-card { max-width: 520px; width: 100%; text-align: center; }
    .pw-logo { font-family: var(--font-display); font-size: 36px; letter-spacing: 4px; color: var(--w); margin-bottom: 48px; }
    .pw-eyebrow { font-family: var(--font-cond); font-size: 12px; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,.6); margin-bottom: 20px; }
    .pw-heading { font-family: var(--font-display); font-size: clamp(48px, 8vw, 80px); line-height: 1; color: var(--w); margin-bottom: 20px; }
    .pw-sub { font-family: var(--font-body); font-size: 17px; color: rgba(255,255,255,.75); line-height: 1.7; margin-bottom: 40px; }
    .pw-divider { width: 48px; height: 3px; background: var(--blue); border-radius: 2px; margin: 0 auto 40px; }
    .pw-form { display: flex; gap: 12px; max-width: 400px; margin: 0 auto 32px; }
    .pw-form input[type="password"] { flex: 1; padding: 14px 18px; border: 1.5px solid rgba(255,255,255,.2); border-radius: 8px; background: rgba(255,255,255,.08); color: var(--w); font-family: var(--font-body); font-size: 15px; }
    .pw-form input[type="password"]::placeholder { color: rgba(255,255,255,.4); }
    .pw-form input[type="password"]:focus { outline: none; border-color: var(--blue); }
    .pw-form button { padding: 14px 24px; background: var(--blue); color: var(--w); border: none; border-radius: 8px; font-family: var(--font-cond); font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; white-space: nowrap; }
    .pw-form button:hover { background: #1535a0; }
    .pw-error { color: #f87171; font-family: var(--font-body); font-size: 14px; margin-top: -20px; margin-bottom: 20px; }
    .pw-notify { margin-top: 40px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,.1); }
    .pw-notify p { font-family: var(--font-cond); font-size: 13px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,.5); margin-bottom: 16px; }
    .pw-notify-form { display: flex; gap: 12px; max-width: 400px; margin: 0 auto; }
    .pw-notify-form input[type="email"] { flex: 1; padding: 12px 16px; border: 1.5px solid rgba(255,255,255,.2); border-radius: 8px; background: rgba(255,255,255,.08); color: var(--w); font-family: var(--font-body); font-size: 15px; }
    .pw-notify-form input[type="email"]::placeholder { color: rgba(255,255,255,.4); }
    .pw-notify-form input[type="email"]:focus { outline: none; border-color: var(--blue); }
    .pw-notify-form button { padding: 12px 20px; background: transparent; color: var(--w); border: 1.5px solid rgba(255,255,255,.3); border-radius: 8px; font-family: var(--font-cond); font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; white-space: nowrap; }
    .pw-notify-form button:hover { border-color: var(--w); }
    .pw-notify-success { color: rgba(255,255,255,.7); font-family: var(--font-body); font-size: 14px; margin-top: 12px; }
    .pw-footer { text-align: center; padding: 24px; font-family: var(--font-cond); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,.3); }
    .pw-footer a { color: rgba(255,255,255,.4); text-decoration: none; }
    .pw-footer a:hover { color: var(--w); }
    @media (max-width: 500px) {
      .pw-form, .pw-notify-form { flex-direction: column; }
    }
  </style>
</head>
<body>

  <div class="pw-wrap">
    <div class="pw-card">

      {% if shop.password_message != blank or section.settings.logo_text != blank %}
        <div class="pw-logo">{{ section.settings.logo_text | default: shop.name }}</div>
      {% endif %}

      <div class="pw-eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="pw-heading">{{ section.settings.heading }}</h1>
      <div class="pw-divider"></div>
      <p class="pw-sub">{{ section.settings.subheading }}</p>

      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <div class="pw-form">
          <input type="password" name="password" placeholder="{{ section.settings.password_placeholder }}" autocomplete="current-password">
          <button type="submit">{{ section.settings.password_button }}</button>
        </div>
        {% if form.errors %}
          <p class="pw-error">{{ section.settings.error_message }}</p>
        {% endif %}
      {% endform %}

      {% if section.settings.show_notify %}
        <div class="pw-notify">
          <p>{{ section.settings.notify_label }}</p>
          {% form 'customer' %}
            <input type="hidden" name="contact[tags]" value="newsletter,waitlist">
            {% if form.posted_successfully? %}
              <p class="pw-notify-success">{{ section.settings.notify_success }}</p>
            {% else %}
              <div class="pw-notify-form">
                <input type="email" name="contact[email]" placeholder="{{ section.settings.notify_placeholder }}">
                <button type="submit">{{ section.settings.notify_button }}</button>
              </div>
            {% endif %}
          {% endform %}
        </div>
      {% endif %}

    </div>
  </div>

  <footer class="pw-footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }} &mdash; <a href="/admin">Store Owner Login</a></p>
  </footer>

</body>
</html>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo / Brand Name", "default": "CALI K9" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Something Big Is Coming" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Coming Soon" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We're working on something for your dog. Real training. Real results. Coming soon." },
    { "type": "text", "id": "password_placeholder", "label": "Password Field Placeholder", "default": "Enter password" },
    { "type": "text", "id": "password_button", "label": "Password Button Text", "default": "Enter" },
    { "type": "text", "id": "error_message", "label": "Wrong Password Message", "default": "Incorrect password. Try again." },
    { "type": "header", "content": "Email Notify" },
    { "type": "checkbox", "id": "show_notify", "label": "Show Email Signup", "default": true },
    { "type": "text", "id": "notify_label", "label": "Notify Label", "default": "Get Early Access" },
    { "type": "text", "id": "notify_placeholder", "label": "Email Placeholder", "default": "your@email.com" },
    { "type": "text", "id": "notify_button", "label": "Notify Button", "default": "Notify Me" },
    { "type": "text", "id": "notify_success", "label": "Success Message", "default": "You're on the list. We'll be in touch." }
  ],
  "presets": [{ "name": "Password Page" }]
}
{% endschema %}
