{% if section.settings.bg == 'dark' %}
  {% assign section_bg = 'var(--gi)' %}
  {% assign text_color = '#fff' %}
  {% assign sub_color = 'rgba(255,255,255,.75)' %}
  {% assign heading_color = '#fff' %}
  {% assign btn_class = 'btn btn-white' %}
{% elsif section.settings.bg == 'off-white' %}
  {% assign section_bg = 'var(--off)' %}
  {% assign text_color = 'var(--text)' %}
  {% assign sub_color = 'var(--gm)' %}
  {% assign heading_color = 'var(--gi)' %}
  {% assign btn_class = 'btn btn-blue' %}
{% else %}
  {% assign section_bg = 'var(--w)' %}
  {% assign text_color = 'var(--text)' %}
  {% assign sub_color = 'var(--gm)' %}
  {% assign heading_color = 'var(--gi)' %}
  {% assign btn_class = 'btn btn-blue' %}
{% endif %}

{% assign img_right = false %}
{% if section.settings.image_position == 'right' %}
  {% assign img_right = true %}
{% endif %}

<section class="section reveal" style="background:{{ section_bg }};color:{{ text_color }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
  <div class="wrap">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;{% if img_right %}direction:rtl{% endif %}">
      <div style="{% if img_right %}direction:ltr{% endif %}">
        {% if section.settings.image %}
          <div style="border-radius:var(--radius);overflow:hidden;aspect-ratio:4/3">
            <img src="{{ section.settings.image | img_url: '900x' }}" alt="{{ section.settings.heading | escape }}" style="width:100%;height:100%;object-fit:cover">
          </div>
        {% else %}
          <div style="border-radius:var(--radius);aspect-ratio:4/3;background:var(--gi);display:flex;align-items:center;justify-content:center">
            <span style="font-family:var(--font-cond);font-size:14px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.3)">Add Image</span>
          </div>
        {% endif %}
      </div>
      <div style="{% if img_right %}direction:ltr{% endif %}">
        {% if section.settings.eyebrow != blank %}
          <div style="font-family:var(--font-cond);font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:{{ sub_color }};margin-bottom:16px">{{ section.settings.eyebrow }}</div>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 style="font-family:var(--font-display);font-size:clamp(32px,4vw,56px);color:{{ heading_color }};line-height:1;margin-bottom:16px">{{ section.settings.heading }}</h2>
          <div style="width:48px;height:3px;background:var(--blue);border-radius:2px;margin-bottom:20px"></div>
        {% endif %}
        {% if section.settings.body != blank %}
          <div style="font-family:var(--font-body);font-size:16px;color:{{ sub_color }};line-height:1.8;margin-bottom:28px">{{ section.settings.body }}</div>
        {% endif %}
        {% if section.settings.show_cta and section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_url }}" class="{{ btn_class }}">{{ section.settings.cta_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .iwt-grid { grid-template-columns: 1fr !important; direction: ltr !important; }
  }
</style>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional)", "default": "" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Choose Cali K9?" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>With over 18 years of experience and 5,000+ dogs trained, Jas Leverette delivers results that last. Our methods are rooted in relationship, structure, and understanding.</p>" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA Button", "default": true },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Learn More" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "default": "/pages/about" },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "off-white", "label": "Off White" },
        { "value": "dark", "label": "Dark Navy" }
      ],
      "default": "white"
    },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    {
      "name": "Image with Text",
      "settings": {
        "heading": "Why Choose Cali K9?",
        "body": "<p>With over 18 years of experience and 5,000+ dogs trained, Jas Leverette delivers results that last.</p>",
        "show_cta": true,
        "cta_text": "Learn More",
        "cta_url": "/pages/about"
      }
    }
  ]
}
{% endschema %}
