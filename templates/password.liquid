{% layout 'password' %}

<div class="pw-wrap">
  <div class="pw-card">

    <div class="pw-logo">{{ shop.name }}</div>
    <div class="pw-eyebrow">Something Big Is Coming</div>
    <h1 class="pw-heading">Coming Soon</h1>
    <div class="pw-divider"></div>
    <p class="pw-sub">We're working on something for your dog. Real training. Real results. Coming soon.</p>

    {% form 'storefront_password' %}
      {% if form.errors %}
        <p class="pw-errors">Incorrect password. Please try again.</p>
      {% endif %}
      <div class="pw-form">
        <input type="password" name="password" placeholder="Enter password" autocomplete="current-password">
        <button type="submit">Enter</button>
      </div>
    {% endform %}

    <div class="pw-notify">
      <p class="pw-notify-label">Get Early Access</p>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter,waitlist">
        {% if form.posted_successfully? %}
          <p class="pw-success">You're on the list. We'll be in touch.</p>
        {% else %}
          <div class="pw-notify-form">
            <input type="email" name="contact[email]" placeholder="your@email.com" autocomplete="email">
            <button type="submit">Notify Me</button>
          </div>
        {% endif %}
      {% endform %}
    </div>

  </div>
</div>
