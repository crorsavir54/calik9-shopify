<div class="prod-card">
  <a href="{{ product.url }}">
    <div class="prod-img">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
      {% else %}
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--off)">
          <span style="font-family:var(--font-cond);font-size:12px;color:var(--gm)">No Image</span>
        </div>
      {% endif %}
    </div>
  </a>
  <div class="prod-info">
    <div class="prod-name">{{ product.title }}</div>
    <div class="prod-price">{{ product.price | money }}</div>
    <form action="/cart/add" method="post" data-ajax-cart>
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="prod-btn">
        {% if product.available %}
          Add to Cart
        {% else %}
          Sold Out
        {% endif %}
      </button>
    </form>
  </div>
</div>
