<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}{% if page_title != shop.name %} | {{ shop.name }}{% endif %}</title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --blue: {{ settings.color_primary | default: '#1A3FAB' }};
      --gi: {{ settings.color_dark | default: '#0a1a5c' }};
      --accent: {{ settings.color_accent | default: '#c9a84c' }};
      --w: {{ settings.color_bg | default: '#ffffff' }};
      --off: {{ settings.color_off_white | default: '#f5f2eb' }};
      --text: {{ settings.color_text | default: '#111111' }};
      --footer-bg: {{ settings.color_footer_bg | default: '#0a1a5c' }};
      --fs-base: {{ settings.base_font_size | default: 16 }}px;
    }
    body { font-size: var(--fs-base); }
  </style>
</head>
<body>

<!-- NAV -->
{% assign nav_menu = linklists[settings.nav_menu] %}
<nav class="site-nav">
  <div class="nav-left">
    <a href="/" class="nav-brand">
      {% if settings.logo %}
        <img src="{{ settings.logo | img_url: '80x80' }}" alt="{{ shop.name }}">
      {% endif %}
      <span class="nav-brand-name">{{ settings.brand_name | default: 'CALI K9' }}</span>
    </a>
    <ul class="nav-links">
      {% if nav_menu != blank %}
        {% for link in nav_menu.links %}
          {% if link.links != blank %}
            <li class="nav-has-dropdown">
              <button {% if link.active %}class="active"{% endif %}>
                {{ link.title }} <span class="nav-chevron">&#9660;</span>
              </button>
              <div class="nav-dropdown">
                {% for child in link.links %}
                  <a href="{{ child.url }}" {% if child.active %}class="active"{% endif %}>{{ child.title }}</a>
                {% endfor %}
              </div>
            </li>
          {% else %}
            <li><a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a></li>
          {% endif %}
        {% endfor %}
      {% else %}
        <li><a href="/" {% if request.path == '/' %}class="active"{% endif %}>Home</a></li>
        <li><a href="/pages/about">About</a></li>
        <li><a href="/collections/all">Shop</a></li>
        <li class="nav-has-dropdown">
          <button>Programs <span class="nav-chevron">&#9660;</span></button>
          <div class="nav-dropdown">
            <a href="/pages/vip">VIP Training</a>
            <a href="/pages/eval">Dog Evaluation</a>
          </div>
        </li>
      {% endif %}
    </ul>
  </div>
  <div class="nav-right">
    {% if settings.show_cart_icon != false %}
    <button class="nav-cart-btn" data-open-cart aria-label="Open cart">
      {% render 'icon-cart' %}
      <span class="cart-count" style="display:none">0</span>
    </button>
    {% endif %}
    {% if settings.nav_cta_text != blank %}
    <a href="{{ settings.nav_cta_url | default: '/pages/eval' }}" class="nav-book">{{ settings.nav_cta_text | default: 'Book Evaluation' }}</a>
    {% endif %}
    <button class="nav-mobile-btn" aria-label="Menu">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</nav>

<!-- MOBILE DRAWER -->
<div class="nav-drawer">
  {% if nav_menu != blank %}
    {% for link in nav_menu.links %}
      {% if link.links != blank %}
        {% for child in link.links %}
          <a href="{{ child.url }}" onclick="this.closest('.nav-drawer').classList.remove('open')">{{ child.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ link.url }}" onclick="this.closest('.nav-drawer').classList.remove('open')">{{ link.title }}</a>
      {% endif %}
    {% endfor %}
  {% else %}
    <a href="/" onclick="this.closest('.nav-drawer').classList.remove('open')">Home</a>
    <a href="/pages/about" onclick="this.closest('.nav-drawer').classList.remove('open')">About</a>
    <a href="/pages/vip" onclick="this.closest('.nav-drawer').classList.remove('open')">VIP Training</a>
    <a href="/pages/eval" onclick="this.closest('.nav-drawer').classList.remove('open')">Dog Evaluation</a>
    <a href="/collections/all" onclick="this.closest('.nav-drawer').classList.remove('open')">Shop</a>
  {% endif %}
  {% if settings.nav_cta_text != blank %}
  <a href="{{ settings.nav_cta_url | default: '/pages/eval' }}" class="book-mobile" onclick="this.closest('.nav-drawer').classList.remove('open')">{{ settings.nav_cta_text | default: 'Book Evaluation' }}</a>
  {% endif %}
</div>

<!-- CART OVERLAY + DRAWER -->
<div class="cart-overlay"></div>
<div class="cart-drawer" role="dialog" aria-modal="true" aria-label="Cart">
  <div class="cart-hd">
    <h2>Your Cart</h2>
    <button class="cart-close" data-close-cart aria-label="Close cart">&times;</button>
  </div>
  <div class="cart-items"></div>
  <div class="cart-ft">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span class="cart-subtotal-val">$0.00</span>
    </div>
    <a href="/checkout" class="cart-checkout">Checkout</a>
    <p style="font-family:var(--font-cond);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--gm);text-align:center;margin-top:12px">&#128274; Secure Checkout</p>
  </div>
</div>

<main>{{ content_for_layout }}</main>

<!-- FOOTER -->
{% assign ft_menu_1 = linklists[settings.footer_menu_1] %}
{% assign ft_menu_2 = linklists[settings.footer_menu_2] %}
{% assign ft_menu_3 = linklists[settings.footer_menu_3] %}
<footer class="site-footer">
  <div class="wrap">
    <div class="ft-grid">
      <div class="ft-brand">
        {% if settings.logo %}
          <img src="{{ settings.logo | img_url: '96x96' }}" alt="{{ shop.name }}">
        {% endif %}
        <div class="ft-brand-name">{{ settings.brand_name | default: 'CALI K9' }}<sup>&#174;</sup></div>
        <p class="ft-tagline">{{ settings.footer_tagline | default: "Professional dog training rooted in relationship, structure, and real-world results. As seen on Netflix's Canine Intervention." }}</p>
        <div class="ft-socials">
          {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" class="ft-s" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          {% endif %}
          {% if settings.social_youtube != blank %}
          <a href="{{ settings.social_youtube }}" class="ft-s" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" class="ft-s" target="_blank" rel="noopener" aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.05a8.16 8.16 0 004.77 1.52V7.14a4.85 4.85 0 01-1-.45z"/>
            </svg>
          </a>
          {% endif %}
        </div>
      </div>

      <div class="ft-col">
        <h4>{{ settings.footer_menu_1_heading | default: 'Programs' }}</h4>
        {% if ft_menu_1 != blank %}
          {% for link in ft_menu_1.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="/pages/vip">VIP Training</a>
          <a href="/pages/eval">Dog Evaluation</a>
        {% endif %}
      </div>

      <div class="ft-col">
        <h4>{{ settings.footer_menu_2_heading | default: 'Shop' }}</h4>
        {% if ft_menu_2 != blank %}
          {% for link in ft_menu_2.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="/collections/all">All Products</a>
          <a href="/collections/equipment">Equipment</a>
          <a href="/collections/apparel">Apparel</a>
          <a href="/collections/treats">Treats</a>
        {% endif %}
      </div>

      <div class="ft-col">
        <h4>{{ settings.footer_menu_3_heading | default: 'Company' }}</h4>
        {% if ft_menu_3 != blank %}
          {% for link in ft_menu_3.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="/pages/about">About Jas</a>
          <a href="/pages/eval">Contact</a>
          <a href="/policies/privacy-policy">Privacy Policy</a>
          <a href="/policies/terms-of-service">Terms</a>
          <a href="/policies/refund-policy">Returns</a>
        {% endif %}
      </div>
    </div>
    <div class="ft-bot">
      <span class="ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ settings.brand_name | default: 'Cali K9' }}&reg;. All rights reserved.</span>
      <span class="ft-copy">{{ settings.footer_email | default: 'training@calik9.com' }}</span>
    </div>
  </div>
</footer>

{{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
